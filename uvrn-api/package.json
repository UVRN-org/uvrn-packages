{
  "name": "@uvrn/api",
  "version": "1.5.2",
  "publishConfig": { "access": "public" },
  "description": "UVRN REST API — HTTP access to bundle processing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": { "uvrn-api": "dist/server.js" },
  "keywords": ["uvrn", "rest-api", "bundle", "protocol"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UVRN-org/uvrn-packages.git",
    "directory": "uvrn-api"
  },
  "homepage": "https://github.com/UVRN-org/uvrn-packages#readme",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepack": "node ../scripts/rewrite-workspace-deps.js",
    "postpack": "node ../scripts/restore-workspace-deps.js"
  },
  "dependencies": {
    "@uvrn/core": "workspace:^",
    "fastify": "^5.7.3",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/helmet": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "pino-pretty": "^10.3.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": { "node": ">=20.0.0" },
  "files": ["dist", "README.md"]
}
