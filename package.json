{
  "name": "uvrn-packages",
  "private": true,
  "description": "UVRN protocol packages — core, SDK, CLI, API, MCP, adapter. Publish to npm under @uvrn scope.",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.7",
      "esbuild": ">=0.25.0"
    }
  },
  "workspaces": [
    "uvrn-core",
    "uvrn-sdk",
    "uvrn-cli",
    "uvrn-api",
    "uvrn-mcp",
    "uvrn-adapter"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "test": "CI=1 pnpm -r run test",
    "lint": "pnpm -r run lint",
    "smoke:consumer": "node scripts/smoke-test-consumer.js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
