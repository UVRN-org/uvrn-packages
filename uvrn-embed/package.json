{
  "name": "@uvrn/embed",
  "version": "2.0.0",
  "description": "Embeddable consensus badges for any webpage — React component and plain JS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/embed.umd.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/embed.umd.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node build-umd.mjs",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "esbuild": "^0.20.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "uvrn",
    "embed",
    "badge",
    "consensus",
    "react",
    "widget"
  ]
}
