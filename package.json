{
  "name": "uvrn-packages",
  "private": true,
  "description": "UVRN protocol packages — core, SDK, CLI, API, MCP, adapter. Publish to npm under @uvrn scope.",
  "workspaces": [
    "uvrn-core",
    "uvrn-sdk",
    "uvrn-cli",
    "uvrn-api",
    "uvrn-mcp",
    "uvrn-adapter"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
